menu "LabGuard network"

    config LABGUARD_WIFI_SSID
        string "Wi-Fi SSID"
        default ""
        help
            2.4 GHz Wi-Fi SSID used by the indoor node.

    config LABGUARD_WIFI_PASSWORD
        string "Wi-Fi password"
        default ""
        help
            Wi-Fi password. Leave empty only for an open test network.

    config LABGUARD_MQTT_URI
        string "MQTT broker URI"
        default ""
        help
            MQTT broker URI, for example mqtt://192.168.1.10:1883.
            Leave empty to keep local-only serial logging.

endmenu

CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_FREERTOS_HZ=1000

CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# ESP32-P4 Function EV Board uses the onboard ESP32-C6 as Wi-Fi co-processor.
CONFIG_ESP_HOST_WIFI_ENABLED=n
CONFIG_ESP_WIFI_REMOTE_ENABLED=y
CONFIG_ESP_WIFI_REMOTE_LIBRARY_HOSTED=y
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_ENABLED=y
CONFIG_ESP_HOSTED_CP_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_P4_DEV_BOARD_FUNC_BOARD=y
# CONFIG_ESP_HOSTED_SPI_HOST_INTERFACE is not set
CONFIG_ESP_HOSTED_SDIO_HOST_INTERFACE=y
CONFIG_ESP_HOSTED_SDIO_SLOT_1=y

# Fill these through `idf.py menuconfig` or sdkconfig.local before flashing.
CONFIG_LABGUARD_WIFI_SSID="李柯岑的iPhone"
CONFIG_LABGUARD_WIFI_PASSWORD="Ljl635415"
CONFIG_LABGUARD_MQTT_URI="mqtt://172.20.10.14:1883"

# Indoor environmental sensor I2C bus (shared with SC2336 camera SCCB)
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_PORT=0
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_SDA_GPIO=7
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_SCL_GPIO=8
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_FREQ_HZ=100000
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_INTERNAL_PULLUPS=y
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_SCAN=y
CONFIG_LABGUARD_INDOOR_SENSOR_I2C_AUTO_DETECT_PINS=y
CONFIG_LABGUARD_SHT3X_ADDR=0x44
CONFIG_LABGUARD_ENS160_ADDR=0x53

# MQ-2 smoke / combustible gas sensor (digital DO line)
CONFIG_LABGUARD_MQ2_ENABLE=y
CONFIG_LABGUARD_MQ2_DO_GPIO=4
CONFIG_LABGUARD_MQ2_ACTIVE_LOW=y
CONFIG_LABGUARD_MQ2_INTERNAL_PULLUP=y

# 4-channel MOSFET module gate pins (active-high by default)
CONFIG_LABGUARD_ACTUATOR_FAN_GPIO=5
CONFIG_LABGUARD_ACTUATOR_FAN_ACTIVE_LOW=n
CONFIG_LABGUARD_ACTUATOR_PUMP_GPIO=6
CONFIG_LABGUARD_ACTUATOR_PUMP_ACTIVE_LOW=n
CONFIG_LABGUARD_ACTUATOR_ALARM_GPIO=9
CONFIG_LABGUARD_ACTUATOR_ALARM_ACTIVE_LOW=n

# PSRAM is required for the MIPI-DSI frame buffer (1024*600*2 = 1.2MB)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_HEX=y
CONFIG_SPIRAM_SPEED_250M=y

# SC2336 camera sensor: native 1024x600 RAW8 30fps so it matches the EK79007
# panel without needing an ISP scaler. The library's default 1280x720 produces
# a "failed to configure format conversion" error.
CONFIG_CAMERA_SC2336=y
CONFIG_CAMERA_SC2336_MIPI_RAW8_1024X600_30FPS=y
CONFIG_CAMERA_SC2336_AUTO_DETECT_MIPI_INTERFACE_SENSOR=y

# The esp_cam_sensor SPI sub-driver does not build cleanly on IDF 6.0 (calls
# spicommon_* APIs with the wrong signatures). We use the MIPI-CSI interface,
# not SPI, so disable the SPI sub-driver entirely to skip those translation
# units.
CONFIG_CAM_CTRL_SPI_ENABLE=n
